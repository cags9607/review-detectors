# Queue
QUEUE_URL=https://deepsee-queue.herokuapp.com/exchange-batch
QUEUE_API_KEY=
QUEUE_KEY=
BATCH_SIZE=8
EMPTY_QUEUE_SLEEP_SECONDS=60

# Scam review detector
SCAM_REVIEW_HF_REPO_ID=Trinotrotolueno/review-scam-adapters
SCAM_REVIEW_SUBFOLDER=scam_reviews
SCAM_REVIEW_MAX_LENGTH=512
SCAM_REVIEW_NO_4BIT=0
SCAM_REVIEW_APPLY_ONE_WORD_MAPPING=1
SCAM_REVIEW_FORCE_UNKNOWN_SINGLE_WORD_CLEAN=1

# AI-generated review detector
AI_REVIEW_HF_REPO_ID=Trinotrotolueno/aigt-loras
AI_REVIEW_SUBDIR_BY_LANG_JSON={"en":"reviews/best"}
AI_REVIEW_DEVICE=cuda
AI_REVIEW_CACHE_POLICY=keep
AI_REVIEW_MAX_LEN=500
AI_REVIEW_BATCH_SIZE=16
AI_REVIEW_WINDOW_AI_THRESHOLD=0.5
AI_REVIEW_PREFER_BF16=1
AI_REVIEW_MIN_WORDS=10

# Shared/private HF auth if needed
HF_TOKEN=

# Combined worker behavior
REVIEW_DETECTORS_REQUIRE_REVIEW_ID=1
REVIEW_DETECTORS_DUPLICATE_REVIEW_ID_POLICY=error
REVIEW_DETECTORS_CACHE_POLICY=keep
